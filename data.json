    "ksData": "<!DOCTYPE html><html lang='en'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0,user-scalable=no'><style>:root{--p:#2563eb;--bg:#0f172a;--t:#f8fafc}body{margin:0;padding:0;background:var(--bg);color:var(--t);font-family:system-ui,-apple-system,sans-serif;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh}#g-cnt{text-align:center;position:relative}canvas{border:2px solid var(--p);background:#020617;box-shadow:0 0 25px rgba(37,99,235,0.4);border-radius:16px;touch-action:none}.hud{position:absolute;top:16px;left:16px;right:16px;display:flex;justify-content:space-between;font-family:monospace;font-size:16px;font-weight:bold;color:#38bdf8;pointer-events:none;text-shadow:0 0 8px rgba(56,189,248,0.6)}.btn{margin-top:16px;background:var(--p);color:#fff;border:none;padding:12px 28px;border-radius:12px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(37,99,235,0.4);transition:all 0.2s}.btn:active{transform:scale(0.95)}</style></head><body><div id='g-cnt'><div class='hud'><div>NODES: <span id='sc'>0</span></div><div>SYNC: <span id='ml'>100%</span></div></div><canvas id='ctx' width='320' height='400'></canvas><button class='btn' onclick='init()'>RESET CORE</button></div><script>const cv=document.getElementById('ctx'),cx=cv.getContext('2d');let sc=0,sync=100,pts=[],t=0,trg={x:160,y:200,r:30};function init(){sc=0;sync=100;pts=[];document.getElementById('sc').innerText=sc;document.getElementById('ml').innerText=sync+'%'}cv.addEventListener('touchstart',e=>{e.preventDefault();clk(e.touches[0].clientX,e.touches[0].clientY)});cv.addEventListener('mousedown',e=>clk(e.clientX,e.clientY));function clk(ex,ey){const r=cv.getBoundingClientRect(),x=ex-r.left,y=ey-r.top;const d=Math.hypot(x-trg.x,y-trg.y);if(d<=trg.r+15){sc+=10;trg.x=Math.random()*240+40;trg.y=Math.random()*300+50;if(sync<100)sync=Math.min(100,sync+5);for(let i=0;i<12;i++)pts.push({x:x,y:y,dx:(Math.random()-0.5)*8,dy:(Math.random()-0.5)*8,c:'#38bdf8',a:1})}else{sync=Math.max(0,sync-10);for(let i=0;i<6;i++)pts.push({x:x,y:y,dx:(Math.random()-0.5)*4,dy:(Math.random()-0.5)*4,c:'#ef4444',a:1})}document.getElementById('sc').innerText=sc;document.getElementById('ml').innerText=sync+'%'}function update(){t+=0.05;cx.clearRect(0,0,320,400);cx.fillStyle='rgba(37,99,235,0.02)';for(let i=0;i<10;i++)cx.fillRect(Math.random()*320,Math.random()*400,2,2);cx.beginPath();cx.arc(trg.x,trg.y,trg.r+Math.sin(t)*3,0,Math.PI*2);cx.strokeStyle=sync<30?'#ef4444':'#2563eb';cx.lineWidth=3;cx.stroke();cx.fillStyle=sync<30?'rgba(239,68,68,0.2)':'rgba(37,99,235,0.1)';cx.fill();cx.fillStyle='#fff';cx.font='12px monospace';cx.textAlign='center';cx.fillText('NAT_CORE',trg.x,trg.y+4);for(let i=pts.length-1;i>=0;i--){let p=pts[i];p.x+=p.dx;p.y+=p.dy;p.a-=0.03;if(p.a<=0){pts.splice(i,1);continue}cx.fillStyle=p.c==='#38bdf8'?'rgba(56,189,248,'+p.a+')':'rgba(239,68,68,'+p.a+')';cx.beginPath();cx.arc(p.x,p.y,3,0,Math.PI*2);cx.fill()}if(sync<=0){cx.fillStyle='rgba(0,0,0,0.85)';cx.fillRect(0,0,320,400);cx.fillStyle='#ef4444';cx.font='18px monospace';cx.textAlign='center';cx.fillText('CORE SYNC CRASHED',160,200)}requestAnimationFrame(update)}update();</script></body></html>"
